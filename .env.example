# ── Core Flask ────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=replace-with-output-of--python-c-import-secrets-print-secrets.token_hex-32

# ── Database (Railway injects this automatically) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis for rate limiting (optional — Railway Redis add-on) ─────────────────
# If not set, rate limiting uses in-memory storage (resets on restart)
REDIS_URL=redis://default:password@host:6379

# ── First admin user (used only by: flask create-admin) ──────────────────────
SEED_ADMIN_EMAIL=you@yourdomain.com
SEED_ADMIN_PASSWORD=choose-a-strong-password
SEED_ADMIN_NAME=Your Name

# ── Legacy single-admin fallback (used only when DATABASE_URL is not set) ─────
ADMIN_EMAIL=admin@tryaiden.ai
ADMIN_PASSWORD_HASH=

# ── App URL ───────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.up.railway.app
COOKIE_DOMAIN=

# ── Discord bot ───────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Amazon Relay automation ───────────────────────────────────────────────────
RELAY_PROFILE_PATH=.browser_profile/
RELAY_HEADLESS=true

# ── Google / Gmail ────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
