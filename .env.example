# ============================================================
# MultiAgent Operations — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── Core / Authentication ────────────────────────────────────
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-64-char-hex-string-here

# Set to 'production' on the live server (disables debug, enables secure cookies)
FLASK_ENV=production

# Admin login credentials
# Generate password hash with:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_EMAIL=admin@tryaiden.ai
ADMIN_PASSWORD_HASH=pbkdf2:sha256:...

# App URL (no trailing slash)
APP_BASE_URL=https://app.tryaiden.ai

# Cookie domain — allows the session cookie to be shared across subdomains.
# Set to the root domain, e.g. 'tryaiden.ai'
COOKIE_DOMAIN=tryaiden.ai

# Server binding (Replit / cloud hosts set PORT automatically)
PORT=5050
HOST=0.0.0.0

# ── Anthropic (Claude) — Content Engine hook generation ─────
# Get key at: https://console.anthropic.com/settings/keys
# If set, the Content Engine uses Claude Haiku for natural AI-written hooks.
# If not set, falls back to a curated static hook bank.
ANTHROPIC_API_KEY=sk-ant-...

# ── Discord ─────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ── Google Ads — Best Care Auto Transport ───────────────────
# https://developers.google.com/google-ads/api/docs/get-started/oauth-cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth2-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth2-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
BEST_CARE_GOOGLE_ADS_CUSTOMER_ID=9876543210

# ── 8x8 Call Tracking — Best Care Auto Transport ───────────
# https://developer.8x8.com/work/reference
EIGHTX8_API_KEY=your-8x8-api-key
EIGHTX8_BASE_URL=https://api.8x8.com
EIGHTX8_ACCOUNT_ID=your-account-id
BEST_CARE_SALES_NUMBER=+17085551234

# ── Competitor Intelligence ─────────────────────────────────
# DataForSEO (preferred): https://dataforseo.com/
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your-dataforseo-password
# SerpAPI (fallback): https://serpapi.com/
SERPAPI_KEY=your-serpapi-key
BEST_CARE_COMPETITOR_DOMAINS=montway.com,uship.com,amerifreight.net,sgautocarriers.com
BEST_CARE_TARGET_KEYWORDS=

# ── Revenue / Profit Assumptions ────────────────────────────
BEST_CARE_AVG_REVENUE_PER_CONVERSION=2500
BEST_CARE_AVG_PROFIT_PER_CONVERSION=450
BEST_CARE_CALL_TO_LEAD_RATE=0.70
BEST_CARE_LEAD_TO_CLOSE_RATE=0.15
